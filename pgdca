<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PGDCA Study Hub</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Segoe UI',Tahoma,sans-serif;}

/* STICKY FOOTER FIX */
html{height:100%;}
body{background:#eaeded;color:#111;display:flex;flex-direction:column;min-height:100vh;}

/* NAVBAR */
.navbar{background:#131921;color:#fff;position:sticky;top:0;z-index:999;width:100%;}

/* TOP ROW — logo + search + hamburger */
.nav-top{display:flex;align-items:center;padding:10px 16px;gap:12px;border-bottom:1px solid #3d464d;}
.logo{display:flex;align-items:center;gap:8px;flex-shrink:0;text-decoration:none;}
.logo-icon{font-size:1.8rem;}
.logo-text{font-size:1.3rem;font-weight:800;color:#fff;letter-spacing:1px;white-space:nowrap;}
.logo-text span{color:#ff9900;}
.search-box{display:flex;flex:1;min-width:0;max-width:600px;}
.search-select{background:#f3f3f3;border:none;padding:10px 8px;border-radius:4px 0 0 4px;color:#555;font-size:.85rem;flex-shrink:0;}
.search-input{flex:1;min-width:0;padding:10px 12px;border:none;outline:none;font-size:.95rem;}
.search-btn{background:#febd69;border:none;padding:10px 18px;border-radius:0 4px 4px 0;cursor:pointer;font-size:1rem;font-weight:700;flex-shrink:0;}
.search-btn:hover{background:#f3a847;}

/* HAMBURGER BUTTON — only on mobile */
.hamburger{display:none;flex-direction:column;justify-content:center;gap:5px;background:none;border:none;cursor:pointer;padding:6px;flex-shrink:0;}
.hamburger span{display:block;width:24px;height:2px;background:#fff;border-radius:2px;transition:all .3s;}
.hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.hamburger.open span:nth-child(2){opacity:0;}
.hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}

/* NAV MENU BAR — desktop */
.nav-main{background:#232f3e;padding:0 16px;overflow-x:auto;}
.nav-menu{display:flex;list-style:none;gap:2px;padding:6px 0;margin:0;}
.nav-item{padding:9px 16px;cursor:pointer;font-size:.9rem;font-weight:600;border-radius:4px;white-space:nowrap;color:#fff;border:1px solid transparent;transition:all .2s;user-select:none;}
.nav-item:hover{background:#37475a;border-color:#fff;}
.nav-item.active{background:#ff9900;color:#131921;}

/* CONTAINER */
.container{max-width:1300px;width:100%;margin:20px auto;padding:0 16px;flex:1;}

/* ── MOBILE RESPONSIVE ── */
@media(max-width:768px){
  /* show hamburger, hide search select */
  .hamburger{display:flex;}
  .search-select{display:none;}
  .logo-text{font-size:1rem;}
  .logo-icon{font-size:1.4rem;}
  .search-input{font-size:.85rem;}
  .search-btn{padding:10px 12px;}

  /* nav menu — hidden by default, slides down on open */
  .nav-main{
    max-height:0;
    overflow:hidden;
    padding:0;
    transition:max-height .35s ease, padding .35s ease;
    background:#232f3e;
  }
  .nav-main.open{
    max-height:400px;
    padding:6px 0;
  }
  .nav-menu{
    flex-direction:column;
    gap:0;
    padding:0;
  }
  .nav-item{
    padding:14px 20px;
    border-radius:0;
    border:none;
    border-bottom:1px solid #37475a;
    font-size:1rem;
  }
  .nav-item:last-child{border-bottom:none;}
  .nav-item:hover{background:#37475a;border-color:transparent;}
}

/* SECTION SWITCHING */
.section{display:none;}
.section.active{display:block;animation:fadeIn .3s ease;}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}

/* CARDS & COMMON */
.card{background:#fff;border-radius:6px;padding:20px;box-shadow:0 2px 8px rgba(0,0,0,.08);}
.sec-title{font-size:1.15rem;font-weight:700;color:#131921;border-bottom:3px solid #ff9900;padding-bottom:8px;margin-bottom:18px;}

/* HOME */
.ticker{background:#232f3e;color:#ff9900;padding:8px 16px;display:flex;align-items:center;gap:12px;overflow:hidden;border-radius:4px;margin-bottom:16px;}
.ticker-label{background:#ff9900;color:#131921;padding:3px 10px;border-radius:3px;font-weight:700;font-size:.8rem;white-space:nowrap;}
.ticker-text{white-space:nowrap;animation:tick 25s linear infinite;font-size:.88rem;}
@keyframes tick{0%{transform:translateX(80vw);}100%{transform:translateX(-100%);}}

.stats{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:18px;}
.stat{background:#fff;border-radius:6px;padding:14px 20px;flex:1;min-width:120px;box-shadow:0 2px 6px rgba(0,0,0,.08);border-bottom:3px solid #ff9900;display:flex;align-items:center;gap:12px;}
.stat-icon{font-size:1.6rem;}
.stat h3{font-size:1.3rem;color:#131921;}
.stat p{color:#888;font-size:.78rem;}

.home-grid{display:grid;grid-template-columns:2fr 1fr;gap:18px;}
@media(max-width:900px){.home-grid{grid-template-columns:1fr;}}

.notice-list{list-style:none;}
.notice-item{display:flex;gap:12px;padding:12px 0;border-bottom:1px solid #eee;align-items:flex-start;}
.notice-item:last-child{border-bottom:none;}
.badge{padding:4px 10px;border-radius:3px;font-size:.75rem;font-weight:700;min-width:60px;text-align:center;flex-shrink:0;}
.badge.new{background:#c45500;color:#fff;}
.badge.exam{background:#232f3e;color:#fff;}
.badge.gen{background:#ff9900;color:#131921;}
.notice-item h4{font-size:.9rem;margin-bottom:3px;color:#111;}
.notice-item p{font-size:.82rem;color:#666;}

.gallery{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px;}
.gal-item{border-radius:6px;overflow:hidden;box-shadow:0 2px 6px rgba(0,0,0,.1);}
.gal-item img{width:100%;height:130px;object-fit:cover;display:block;}
.gal-item p{padding:8px;text-align:center;font-size:.82rem;font-weight:600;background:#fff;}

.sidebar{display:flex;flex-direction:column;gap:16px;}
.qlink-list{list-style:none;}
.qlink-list li{padding:9px 0;border-bottom:1px solid #eee;cursor:pointer;font-size:.88rem;display:flex;align-items:center;gap:8px;transition:color .2s;}
.qlink-list li:hover{color:#ff9900;}
.qlink-list li:last-child{border-bottom:none;}
.qlink-list li .qi{color:#ff9900;width:16px;text-align:center;}

/* SEMESTER */
.sem-tabs{display:flex;flex-wrap:wrap;background:#f0f2f5;border-radius:6px;margin-bottom:20px;overflow:hidden;}
.sem-tab{flex:1;padding:12px 16px;cursor:pointer;font-weight:600;text-align:center;font-size:.88rem;border:none;background:none;min-width:80px;transition:background .2s;}
.sem-tab:hover{background:#ddd;}
.sem-tab.active{background:#232f3e;color:#fff;}
.sem-content{display:none;}
.sem-content.active{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;}
.sub-card{background:#f8f9fa;border-left:4px solid #ff9900;border-radius:4px;padding:16px;}
.sub-card h4{font-size:.92rem;margin-bottom:6px;color:#131921;}
.sub-card p{font-size:.82rem;color:#666;margin-bottom:10px;}
.sub-meta{display:flex;justify-content:space-between;font-size:.78rem;color:#888;}
.tag{padding:2px 8px;border-radius:3px;font-size:.72rem;font-weight:700;}
.tag.th{background:#e8f4fd;color:#1565c0;}
.tag.pr{background:#e8f5e9;color:#2e7d32;}

/* PYQ */
.pyq-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:18px;}
.pyq-card{background:#fff;border-radius:6px;padding:20px;box-shadow:0 2px 8px rgba(0,0,0,.08);border-top:4px solid #ff9900;}
.pyq-card h3{font-size:.95rem;margin-bottom:12px;color:#131921;}
.pyq-card ul{list-style:none;margin-bottom:14px;}
.pyq-card li{padding:7px 0;border-bottom:1px dashed #eee;font-size:.85rem;color:#444;display:flex;align-items:center;gap:8px;}
.pyq-card li:last-child{border-bottom:none;}
.dl-btn{background:#232f3e;color:#fff;border:none;padding:10px;border-radius:4px;cursor:pointer;font-weight:600;width:100%;font-size:.88rem;transition:background .2s;}
.dl-btn:hover{background:#ff9900;color:#131921;}

/* VIDEO */
.vid-filter{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:18px;}
.flt-btn{padding:6px 16px;border-radius:20px;border:1px solid #ddd;background:#fff;cursor:pointer;font-size:.83rem;transition:all .2s;}
.flt-btn.active,.flt-btn:hover{background:#232f3e;color:#fff;border-color:#232f3e;}
.vid-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:18px;}
.vid-card{background:#fff;border-radius:8px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.08);transition:transform .2s;}
.vid-card:hover{transform:translateY(-3px);}
.vid-thumb{position:relative;height:160px;display:flex;align-items:center;justify-content:center;cursor:pointer;}
.vid-thumb.c1{background:linear-gradient(135deg,#232f3e,#37475a);}
.vid-thumb.c2{background:linear-gradient(135deg,#1a3c5e,#2d6a9f);}
.vid-thumb.c3{background:linear-gradient(135deg,#2d4a1e,#4a7c30);}
.vid-thumb.c4{background:linear-gradient(135deg,#5c1f1f,#a33333);}
.play-btn{font-size:3rem;color:rgba(255,255,255,.85);}
.vid-label{position:absolute;top:8px;left:8px;background:#ff9900;color:#131921;font-size:.72rem;font-weight:700;padding:3px 8px;border-radius:3px;}
.vid-dur{position:absolute;bottom:8px;right:8px;background:rgba(0,0,0,.75);color:#fff;padding:2px 7px;border-radius:3px;font-size:.75rem;}
.vid-info{padding:14px;}
.vid-info h3{font-size:.95rem;margin-bottom:5px;color:#131921;}
.vid-info p{font-size:.82rem;color:#666;margin-bottom:6px;}
.vid-meta{display:flex;justify-content:space-between;font-size:.75rem;color:#888;margin-top:6px;}

/* HELP */
.help-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:18px;margin-bottom:28px;}
.help-card{background:#f8f9fa;border-radius:6px;padding:20px;border-top:3px solid #ff9900;}
.help-card h3{font-size:.95rem;margin-bottom:12px;color:#131921;}
.help-card ul{list-style:none;}
.help-card li{padding:8px 0;border-bottom:1px dashed #ddd;font-size:.85rem;color:#444;cursor:pointer;display:flex;align-items:center;gap:8px;}
.help-card li:hover{color:#ff9900;}
.help-card li:last-child{border-bottom:none;}
.contact-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:14px;margin-top:16px;}
.con-card{text-align:center;padding:22px 14px;background:#f8f9fa;border-radius:6px;border-bottom:3px solid #ff9900;}
.con-icon{font-size:2rem;margin-bottom:8px;}
.con-card h4{font-size:.9rem;color:#131921;margin-bottom:4px;}
.con-card p{font-size:.82rem;color:#666;}

/* FOOTER — always at bottom */
footer{background:#131921;color:#fff;padding:36px 16px 16px;margin-top:auto;width:100%;}
.footer-grid{max-width:1300px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:26px;}
.footer-col h3{color:#ff9900;margin-bottom:12px;font-size:1rem;}
.footer-col p{color:#aaa;font-size:.85rem;line-height:1.7;}
.footer-col ul{list-style:none;}
.footer-col li{margin-bottom:7px;}
.footer-col a{color:#ccc;text-decoration:none;font-size:.85rem;}
.footer-col a:hover{color:#ff9900;}
.social{display:flex;gap:10px;margin-top:12px;}
.social a{color:#fff;background:#232f3e;width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.85rem;text-decoration:none;transition:background .2s;}
.social a:hover{background:#ff9900;color:#131921;}
.footer-line{max-width:1300px;margin:22px auto 0;border:none;border-top:1px solid #37475a;}
.copy{text-align:center;padding:14px 0 0;color:#888;font-size:.82rem;}
.copy span{color:#ff9900;}

/* ===== MODAL ===== */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:2000;align-items:center;justify-content:center;padding:16px;}
.modal-overlay.open{display:flex;animation:fadeIn .2s ease;}
.modal-box{background:#fff;border-radius:10px;max-width:680px;width:100%;max-height:88vh;overflow-y:auto;box-shadow:0 8px 32px rgba(0,0,0,.25);position:relative;}
.modal-header{background:#232f3e;color:#fff;padding:18px 22px;border-radius:10px 10px 0 0;display:flex;justify-content:space-between;align-items:center;position:sticky;top:0;z-index:10;}
.modal-header h2{font-size:1rem;font-weight:700;line-height:1.4;}
.modal-close{background:none;border:none;color:#fff;font-size:1.5rem;cursor:pointer;padding:0 4px;line-height:1;}
.modal-close:hover{color:#ff9900;}
.modal-body{padding:22px;}
.m-badge{display:inline-block;padding:3px 12px;border-radius:20px;font-size:.75rem;font-weight:700;margin-bottom:14px;}
.m-badge.th{background:#e8f4fd;color:#1565c0;}
.m-badge.pr{background:#e8f5e9;color:#2e7d32;}
.m-section{margin-bottom:18px;}
.m-section h4{font-size:.88rem;font-weight:700;color:#131921;border-left:3px solid #ff9900;padding-left:10px;margin-bottom:10px;}
.m-section ul{list-style:none;padding:0;}
.m-section ul li{padding:7px 0;border-bottom:1px solid #f0f0f0;font-size:.85rem;color:#444;display:flex;gap:8px;}
.m-section ul li:last-child{border-bottom:none;}
.m-section ul li::before{content:"▸";color:#ff9900;flex-shrink:0;}
.m-section p{font-size:.85rem;color:#555;line-height:1.7;}
.m-tip{background:#fffbea;border:1px solid #ffe082;border-radius:6px;padding:12px 14px;font-size:.83rem;color:#6d4c00;margin-top:6px;}
.m-tip strong{display:block;margin-bottom:4px;color:#e65100;}

/* PYQ question style */
.pyq-q{background:#f8f9fa;border-radius:6px;padding:14px 16px;margin-bottom:12px;border-left:4px solid #ff9900;}
.pyq-q .qno{font-size:.75rem;font-weight:700;color:#ff9900;margin-bottom:5px;}
.pyq-q p{font-size:.86rem;color:#333;line-height:1.6;margin-bottom:6px;}
.pyq-q .marks{font-size:.75rem;color:#888;font-weight:600;}
.pyq-yr{display:inline-block;background:#232f3e;color:#fff;font-size:.72rem;padding:2px 9px;border-radius:3px;margin-bottom:14px;}

/* sub-card clickable */
.sub-card{cursor:pointer;transition:box-shadow .2s,transform .2s;}
.sub-card:hover{box-shadow:0 4px 16px rgba(255,153,0,.25);transform:translateY(-2px);}
.sub-card .open-hint{font-size:.75rem;color:#ff9900;margin-top:6px;font-weight:600;}

/* pyq list item clickable */
.pyq-card li{cursor:pointer;transition:color .2s;}
.pyq-card li:hover{color:#ff9900;}
</style>
</head>
