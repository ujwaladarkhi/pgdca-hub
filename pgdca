function openSubject(id){
  var d = subjectData[id];
  if(!d) return;
  document.getElementById('modalTitle').textContent = d.title;
  var badge = d.type === 'pr' ? '<span class="m-badge pr">Practical – ' + d.credits + ' Credits</span>' : '<span class="m-badge th">Theory – ' + d.credits + ' Credits</span>';
  var topicsHtml = d.topics.map(function(t){ return '<li>' + t + '</li>'; }).join('');
  document.getElementById('modalBody').innerHTML =
    badge +
    '<div class="m-section"><h4>📖 Subject Overview</h4><p>' + d.desc + '</p></div>' +
    '<div class="m-section"><h4>📋 Topics / Syllabus</h4><ul>' + topicsHtml + '</ul></div>' +
    '<div class="m-tip"><strong>⭐ Important for Exam:</strong>' + d.imp + '</div>' +
    '<div class="m-tip" style="margin-top:10px;background:#e8f5e9;border-color:#a5d6a7;color:#1b5e20;"><strong>💡 Study Tip:</strong>' + d.note + '</div>';
  document.getElementById('modalOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function openPYQ(id){
  var d = pyqData[id];
  if(!d) return;
  document.getElementById('modalTitle').textContent = d.title;
  var qHtml = d.questions.map(function(q, i){
    return '<div class="pyq-q"><div class="qno">Q' + (i+1) + '</div><p>' + q.q + '</p><div class="marks">[' + q.marks + ']</div></div>';
  }).join('');
  document.getElementById('modalBody').innerHTML =
    '<span class="pyq-yr">📅 ' + d.year + ' &nbsp;|&nbsp; ' + d.sem + '</span>' +
    qHtml +
    '<div class="m-tip"><strong>📝 Note:</strong> Ye sample/model questions hain. Actual paper thoda alag ho sakta hai. Practice ke liye ye sab zaroor solve karo!</div>';
  document.getElementById('modalOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal(e){
  if(e.target === document.getElementById('modalOverlay')) closeModalNow();
}
function closeModalNow(){
  document.getElementById('modalOverlay').classList.remove('open');
  document.body.style.overflow = '';
}
document.addEventListener('keydown', function(e){
  if(e.key === 'Escape') closeModalNow();
});
</script>
